<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tagging_coordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <org.fossify.commons.views.MyAppBarLayout
        android:id="@+id/tagging_appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/tagging_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/color_primary"
            app:title="@string/tag_faces_title"
            app:titleTextAppearance="@style/AppTheme.ActionBar.TitleTextStyle" />

    </org.fossify.commons.views.MyAppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tagging_grid"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="1dp"
        android:paddingTop="1dp"
        android:paddingEnd="1dp"
        android:paddingBottom="64dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <org.fossify.commons.views.MyTextView
        android:id="@+id/tagging_placeholder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="24dp"
        android:visibility="gone"
        tools:text="Žiadne tváre" />

    <LinearLayout
        android:id="@+id/tagging_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/color_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="6dp">

        <org.fossify.commons.views.MyTextView
            android:id="@+id/tagging_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:textColor="#FFFFFFFF"
            tools:text="Vybrané: 0" />

        <Button
            android:id="@+id/tagging_btn_secondary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:visibility="gone"
            tools:text="Toto nie je" />

        <Button
            android:id="@+id/tagging_btn_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Priradiť" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
