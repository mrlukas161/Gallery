<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/comparator_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/compare_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@android:string/cancel"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FFFFFFFF" />

        <org.fossify.commons.views.MyTextView
            android:id="@+id/compare_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFFFF"
            tools:text="Podrž = označ na zmazanie" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <com.alexvasilkov.gestures.GestureImageView
                android:id="@+id/compare_left"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/compare_left_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:background="#99000000"
                android:padding="4dp"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp"
                tools:text="IMG_001.jpg · ostrosť 100% ★" />

        </FrameLayout>

        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="#FFFFFFFF" />

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <com.alexvasilkov.gestures.GestureImageView
                android:id="@+id/compare_right"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <org.fossify.commons.views.MyTextView
                android:id="@+id/compare_right_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:background="#99000000"
                android:padding="4dp"
                android:textColor="#FFFFFFFF"
                android:textSize="11sp"
                tools:text="IMG_002.jpg · ostrosť 74%" />

        </FrameLayout>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/compare_strip"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#22FFFFFF"
        android:orientation="horizontal" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/color_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="6dp">

        <org.fossify.commons.views.MyTextView
            android:id="@+id/compare_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:textColor="#FFFFFFFF"
            tools:text="Označené: 0" />

        <Button
            android:id="@+id/compare_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Vymazať označené" />

    </LinearLayout>

</LinearLayout>
